# =========================================================
# OpenRouter (LLM Provider via proxy unificado)
# Obtenha sua chave em: https://openrouter.ai/keys
# =========================================================
OPENROUTER_API_KEY=sk-or-v1-troque-aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modelo principal do agente (suporta tool-calling)
# Sugestoes: anthropic/claude-sonnet-4, openai/gpt-4o, google/gemini-2.5-pro
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Modelo barato/rapido para o classificador de seguranca
# Sugestoes: openai/gpt-4o-mini, anthropic/claude-haiku-4-5, google/gemini-2.5-flash
OPENROUTER_CLASSIFIER_MODEL=openai/gpt-4o-mini

# Headers de boa cidadania exigidos/recomendados pelo OpenRouter
APP_REFERER=http://localhost:8000
APP_TITLE=Azapfy Suporte IA

# =========================================================
# Tavily (Web Search restrito a azapfy.com.br)
# Obtenha sua chave em: https://app.tavily.com
# =========================================================
TAVILY_API_KEY=tvly-troque-aqui

# =========================================================
# RAG / ChromaDB
# =========================================================
CHROMA_PERSIST_DIR=./chroma_db
PDF_PATH=./docs/base.pdf

# Modelo de embeddings local (rodado via sentence-transformers/HuggingFace)
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =========================================================
# Tuning
# =========================================================
LLM_TEMPERATURE=0.2
RAG_TOP_K=4
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
