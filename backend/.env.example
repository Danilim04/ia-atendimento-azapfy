# --- Servidor ---
PORT=8080
LOG_LEVEL=info
PUBLIC_BASE_URL=

# --- Chatwoot ---
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
# Autenticação do webhook: use um dos dois (token na URL ?token=... OU HMAC).
WEBHOOK_TOKEN=
WEBHOOK_SECRET=

# --- Etiquetas (gate de borda / roteamento) ---
# LABEL_BOT vazio = processa toda mensagem de entrada do contato.
LABEL_BOT=fila-bot
LABEL_HUMANO=fila-humano

# --- Mongo da Azapfy (lookup de usuário por login — a 1ª tool) ---
MONGO_URI=
MONGO_DB=azapfy
MONGO_COLLECTION=users
MONGO_TIMEOUT=8s

# --- Cérebro Python (Contrato A, POST /chat) ---
BRAIN_BASE_URL=http://localhost:8001
BRAIN_TIMEOUT=60s

# --- Identidade / gate ---
# Dado pedido na confirmação anti-impersonação: email (default) | nome
CONFIRM_FIELD=email
MAX_TENTATIVAS=3
IDENTITY_TTL=24h

# --- Persistência ---
DB_PATH=gateway.db

# --- SAC / chamados (tools de dados que o cérebro chama via /tools/sac/*) ---
# Opcional: sem SAC_BASE_URL a API de tools não é exposta. Sem TOOLS_API_TOKEN
# ela também não sobe (segredo compartilhado cérebro↔gateway, header X-Tools-Token).
SAC_BASE_URL=
SAC_PORTAL_URL=https://atendimento.azapfy.com.br
# Login privilegiado (SAC/super/GESTOR) que passa no IdentificaUsuario do SAC e
# permite definir a prioridade via /incidente/editar. Vazio = chamado nasce sem
# prioridade (atendente triagem); a criação continua funcionando.
SAC_SERVICE_COD=
SAC_GRUPO_EMP=AZAPERS
SAC_EMPRESA=AZAPFY
SAC_TIMEZONE=America/Sao_Paulo
SAC_API_TOKEN=
SAC_CONFIG_TTL=10m
TOOLS_API_TOKEN=
